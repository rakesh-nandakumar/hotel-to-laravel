# --- LOCAL DEV ONLY ---
# Where Vite's dev server proxies /api and /sanctum to (see vite.config.ts).
# Must match the scheme+host+port `php artisan serve` actually prints —
# plain http://127.0.0.1:8000 by default. Leave unset and it defaults to
# that same value, so a fresh clone works with no .env at all.
VITE_DEV_API_PROXY_TARGET=http://127.0.0.1:8000

# --- PRODUCTION BUILD ONLY (npm run build) ---
# Absolute origin of the Laravel API. Set this when the SPA and API are on
# DIFFERENT origins (e.g. SPA on https://demo.hms.vellixglobal.com, API on
# https://api.demo.hms.vellixglobal.com). No trailing slash.
#
# Leave EMPTY / unset for local dev — VITE_DEV_API_PROXY_TARGET above handles
# it instead, so same-origin relative paths just work.
# VITE_API_URL=https://api.demo.hms.vellixglobal.com

# Realtime uses client-side polling (see src/lib/socket.ts) — no websocket/
# Reverb env is needed on shared cPanel hosting.
