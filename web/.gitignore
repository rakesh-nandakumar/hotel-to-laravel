# dependencies — never commit; the host (Vercel) installs these itself.
# Committing node_modules from Windows breaks the .bin/* executable bit on
# Vercel's Linux builders (e.g. "tsc: Permission denied", exit 126).
node_modules/

# build output — Vercel rebuilds this
dist/

# local env
.env
.env.local
.env.*.local

# vercel / tooling
.vercel/
*.log
*.tsbuildinfo
.DS_Store

# Playwright
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
/playwright/.auth/
