// Mount View Hotel — HMS + POS + Venue Booking
// CONVENTIONS
// - All money values are integer LKR minor units ("cents", 1 LKR = 100 cents).
//   USD is a DISPLAY conversion only (Setting: currency.usd_rate).
// - Every financially-relevant row records staffId + timestamp.
// - Multi-property ready: Room/Venue/User hang off Property (one seeded now).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // DATABASE_URL: runtime connection (on Supabase use the transaction pooler,
  //   port 6543, with ?pgbouncer=true&connection_limit=1)
  // DIRECT_URL: direct/session connection for migrations (port 5432)
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────── Core / config ───────────────────────────────

model Property {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  rooms     Room[]
  venues    Venue[]
  users     User[]
}

enum SettingType {
  TEXT
  NUMBER
  PERCENT
  MONEY
  BOOLEAN
  JSON
  TIME
}

model Setting {
  key       String      @id
  value     String // JSON-encoded value
  type      SettingType
  category  String // hotel | billing | policies | pricing | loyalty | currency | venue | misc
  label     String
  hint      String?
  updatedAt DateTime    @updatedAt
  updatedBy String?
}

// ─────────────────────────────── Staff & access ──────────────────────────────

enum Role {
  SYSTEM_ADMIN // highest privilege — integrations, gateways, deep settings
  OWNER
  MANAGER
  HOUSEKEEPER
  CHEF
  SECURITY
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  role         Role
  passwordHash String
  pinHash      String? // 4-6 digit POS quick-switch PIN
  active       Boolean  @default(true)
  propertyId   String?
  property     Property? @relation(fields: [propertyId], references: [id])
  createdAt    DateTime @default(now())

  // Payroll (LKR cents) — Owner-managed
  baseSalary       Int     @default(0) // monthly basic
  otHourlyRate     Int     @default(0) // overtime per hour
  monthlyAllowance Int     @default(0)
  epfEnabled       Boolean @default(true)
  epfNumber        String?

  attendance        Attendance[]
  shifts            Shift[]
  folioLines        FolioLine[]
  payments          Payment[]
  orders            Order[]
  housekeepingTasks HousekeepingTask[]
  maintenanceLogged MaintenanceIssue[] @relation("loggedBy")
  auditLogs         AuditLog[]
  roomItemChecks    RoomItemCheck[]
  visitorLogs       VisitorLog[]
  loyaltyTxns       LoyaltyTransaction[]
  nightAudits       NightAudit[]
  payrollLines      PayrollLine[]
  payrollRuns       PayrollRun[]         @relation("payrollRunBy")
}

// ─────────────────────────────────── Payroll ─────────────────────────────────

enum PayrollStatus {
  DRAFT // editable — OT/bonus/deductions adjustable per line
  FINALIZED // locked — lines can be marked paid
}

model PayrollRun {
  id          String        @id @default(cuid())
  month       String        @unique // "2026-07"
  status      PayrollStatus @default(DRAFT)
  runById     String
  runBy       User          @relation("payrollRunBy", fields: [runById], references: [id])
  createdAt   DateTime      @default(now())
  finalizedAt DateTime?
  lines       PayrollLine[]
}

model PayrollLine {
  id            String     @id @default(cuid())
  runId         String
  run           PayrollRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  userId        String
  user          User       @relation(fields: [userId], references: [id])
  baseSalary    Int // snapshot at generation
  workedHours   Float      @default(0) // from attendance
  otHours       Float      @default(0) // auto: hours beyond standard, editable
  otPay         Int        @default(0)
  allowance     Int        @default(0)
  bonus         Int        @default(0)
  deduction     Int        @default(0) // advances, no-pay etc.
  deductionNote String?
  gross         Int        @default(0)
  epfEmployee   Int        @default(0) // employee EPF (deducted)
  epfEmployer   Int        @default(0) // employer EPF contribution (not deducted)
  etf           Int        @default(0) // employer ETF contribution
  netPay        Int        @default(0)
  paid          Boolean    @default(false)
  paidAt        DateTime?

  @@unique([runId, userId])
}

model Attendance {
  id       String    @id @default(cuid())
  userId   String
  user     User      @relation(fields: [userId], references: [id])
  clockIn  DateTime
  clockOut DateTime?
  note     String?

  @@index([userId, clockIn])
}

model Shift {
  id          String    @id @default(cuid())
  staffId     String
  staff       User      @relation(fields: [staffId], references: [id])
  openedAt    DateTime  @default(now())
  closedAt    DateTime?
  openingCash Int // LKR cents counted at open
  closingCash Int? // counted at close
  expectedCash Int? // opening + cash payments - cash refunds during shift
  variance    Int? // closingCash - expectedCash
  notes       String?
  payments    Payment[]
}

// ─────────────────────────────── Rooms & rates ───────────────────────────────

enum RoomStatus {
  AVAILABLE
  OCCUPIED
  DIRTY
  MAINTENANCE
}

model RoomType {
  id                String   @id @default(cuid())
  name              String   @unique
  maxOccupancy      Int      @default(2) // ⚠ pending from owner — editable
  bedConfig         String   @default("TBC — pending from owner")
  amenities         Json     @default("[]")
  weekdayRate       Int // LKR cents / night
  weekendRate       Int // LKR cents / night (Sat, Sun + public holidays)
  itemChecklist     Json // template: string[] (report §4.6) — editable per room type
  cleaningChecklist Json // template: string[] (report §4.6)
  rooms             Room[]
  seasonalRates     SeasonalRate[]
}

model Room {
  id         String     @id @default(cuid())
  number     String     @unique
  roomTypeId String
  roomType   RoomType   @relation(fields: [roomTypeId], references: [id])
  floor      String     @default("")
  view       String     @default("")
  amenities  Json       @default("[]")
  status     RoomStatus @default(AVAILABLE)
  notes      String?
  propertyId String
  property   Property   @relation(fields: [propertyId], references: [id])

  reservationRooms  ReservationRoom[]
  housekeepingTasks HousekeepingTask[]
  maintenanceIssues MaintenanceIssue[]
  roomItemChecks    RoomItemCheck[]
  orders            Order[]
}

// Seasonal/peak override: within [startDate, endDate] this nightly rate wins.
model SeasonalRate {
  id         String   @id @default(cuid())
  roomTypeId String
  roomType   RoomType @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)
  name       String // e.g. "December Peak"
  startDate  DateTime @db.Date
  endDate    DateTime @db.Date
  rate       Int // LKR cents / night, all days in range
}

model Package {
  id                    String        @id @default(cuid())
  code                  String        @unique // RO | BB | HB | FB
  name                  String
  description           String        @default("")
  pricePerPersonPerNight Int          @default(0) // LKR cents, added on top of room rate
  mealInclusions        Json          @default("[]")
  active                Boolean       @default(true)
  reservations          Reservation[]
}

// ─────────────────────────────── Guests & CRM ────────────────────────────────

model Guest {
  id            String   @id @default(cuid())
  name          String
  email         String?
  phone         String?
  idNumber      String? // NIC / passport — required at check-in
  nationality   String?
  preferences   String?
  loyaltyPoints Int      @default(0)
  lifetimeSpend Int      @default(0) // LKR cents
  createdAt     DateTime @default(now())

  reservations  Reservation[]
  venueBookings VenueBooking[]
  loyaltyTxns   LoyaltyTransaction[]
  billedRooms   ReservationRoom[]    @relation("billTo")
}

model LoyaltyTransaction {
  id        String   @id @default(cuid())
  guestId   String
  guest     Guest    @relation(fields: [guestId], references: [id])
  points    Int // + earn, - redeem
  reason    String
  refType   String? // FOLIO | ORDER | VENUE
  refId     String?
  staffId   String?
  staff     User?    @relation(fields: [staffId], references: [id])
  createdAt DateTime @default(now())
}

model CorporateAccount {
  id              String        @id @default(cuid())
  companyName     String
  contactName     String?
  phone           String?
  email           String?
  address         String?
  discountPct     Float         @default(0) // negotiated % off room rates
  creditLimit     Int           @default(0) // LKR cents, 0 = unlimited
  active          Boolean       @default(true)
  createdAt       DateTime      @default(now())
  reservations    Reservation[]
  payments        Payment[] // month-end settlements
}

// ─────────────────────────── Reservations & folios ───────────────────────────

enum Channel {
  BOOKING_COM
  WEBSITE
  PHONE
  WALKIN
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
  NO_SHOW
}

model GroupBooking {
  id           String        @id @default(cuid())
  reference    String        @unique // e.g. GRP-0001
  name         String // tour/company name
  contactName  String?
  contactPhone String?
  notes        String?
  createdAt    DateTime      @default(now())
  reservations Reservation[]
}

model Reservation {
  id                 String            @id @default(cuid())
  code               String            @unique // RSV-0001
  guestId            String
  guest              Guest             @relation(fields: [guestId], references: [id])
  channel            Channel
  status             ReservationStatus @default(CONFIRMED)
  checkIn            DateTime          @db.Date
  checkOut           DateTime          @db.Date
  adults             Int               @default(1)
  children           Int               @default(0) // under-4s free per policy setting
  packageId          String?
  package            Package?          @relation(fields: [packageId], references: [id])
  groupBookingId     String?
  groupBooking       GroupBooking?     @relation(fields: [groupBookingId], references: [id])
  corporateAccountId String?
  corporateAccount   CorporateAccount? @relation(fields: [corporateAccountId], references: [id])
  notes              String?
  depositDue         Int               @default(0) // LKR cents, from Setting % at booking
  preCheckIn         Json? // guest-submitted pre-arrival form
  checkedInAt        DateTime?
  checkedOutAt       DateTime?
  cancelledAt        DateTime?
  cancelReason       String?
  createdAt          DateTime          @default(now())

  rooms          ReservationRoom[]
  folio          Folio?
  roomItemChecks RoomItemCheck[]
  orders         Order[]
}

model ReservationRoom {
  id            String      @id @default(cuid())
  reservationId String
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  roomId        String
  room          Room        @relation(fields: [roomId], references: [id])
  nightlyRate   Int // LKR cents — locked at booking (after corporate discount)
  // Group bookings: bill this room's charges to a specific guest instead of the group invoice
  billToGuestId String?
  billToGuest   Guest?      @relation("billTo", fields: [billToGuestId], references: [id])

  @@unique([reservationId, roomId])
}

enum FolioType {
  GUEST // room stay invoice
  VENUE // separate venue invoice type
}

enum FolioStatus {
  OPEN
  SETTLED
  VOID
}

model Folio {
  id             String       @id @default(cuid())
  type           FolioType
  status         FolioStatus  @default(OPEN)
  invoiceNo      String?      @unique // assigned at settlement, e.g. INV-2026-00012 / VNU-2026-0003
  reservationId  String?      @unique
  reservation    Reservation? @relation(fields: [reservationId], references: [id])
  venueBookingId String?      @unique
  venueBooking   VenueBooking? @relation(fields: [venueBookingId], references: [id])
  createdAt      DateTime     @default(now())
  settledAt      DateTime?

  lines    FolioLine[]
  payments Payment[]
}

enum LineSource {
  ROOM
  PACKAGE
  RESTAURANT
  MINIBAR
  VENUE
  LAUNDRY
  SURCHARGE // early check-in / late check-out
  SERVICE_CHARGE
  VAT
  DISCOUNT
  DAMAGE
  ADJUSTMENT
  LOYALTY_REDEMPTION
}

model FolioLine {
  id          String     @id @default(cuid())
  folioId     String
  folio       Folio      @relation(fields: [folioId], references: [id], onDelete: Cascade)
  source      LineSource
  description String
  qty         Float      @default(1)
  unitPrice   Int // LKR cents (negative for discounts/redemptions)
  amount      Int // qty * unitPrice, LKR cents
  orderId     String? // link back to POS order
  order       Order?     @relation(fields: [orderId], references: [id])
  staffId     String
  staff       User       @relation(fields: [staffId], references: [id])
  voided      Boolean    @default(false)
  voidReason  String?
  createdAt   DateTime   @default(now())

  @@index([folioId])
}

// ─────────────────────────────── Restaurant POS ──────────────────────────────

model MenuCategory {
  id        String     @id @default(cuid())
  name      String     @unique
  sortOrder Int        @default(0)
  isMinibar Boolean    @default(false) // minibar items post to folio as MINIBAR
  active    Boolean    @default(true)
  items     MenuItem[]
}

model MenuItem {
  id          String       @id @default(cuid())
  itemNo      Int?         @unique // printed menu number — quick POS entry ("#12")
  name        String
  categoryId  String
  category    MenuCategory @relation(fields: [categoryId], references: [id])
  price       Int // LKR cents
  description String       @default("")
  soldOut     Boolean      @default(false)
  active      Boolean      @default(true)
  recipe      RecipeItem[]
  orderItems  OrderItem[]
}

model Ingredient {
  id                String            @id @default(cuid())
  name              String            @unique
  unit              String // g | ml | pcs | kg ...
  stockQty          Float             @default(0)
  lowStockThreshold Float             @default(0)
  recipeItems       RecipeItem[]
  batches           IngredientBatch[]
}

// Food expiry tracking: stock received in batches with expiry dates.
// Order deductions drain batches FEFO (first-expiring-first-out); expired /
// expiring-soon batches raise alerts and can be written off with a reason.
model IngredientBatch {
  id           String     @id @default(cuid())
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  qty          Float // remaining
  initialQty   Float
  expiryDate   DateTime?  @db.Date
  receivedAt   DateTime   @default(now())
  note         String?

  @@index([ingredientId, expiryDate])
}

model RecipeItem {
  id           String     @id @default(cuid())
  menuItemId   String
  menuItem     MenuItem   @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  qty          Float // per 1 portion

  @@unique([menuItemId, ingredientId])
}

// Laundry price list — editable by Manager; charges post to the guest folio
model LaundryItem {
  id     String  @id @default(cuid())
  name   String  @unique
  price  Int // LKR cents per piece
  active Boolean @default(true)
}

enum OrderType {
  ROOM_GUEST
  WALKIN
}

// Dine-in gets table service (service charge applies); takeaway does not
// (service charge is waived — VAT still applies). Room-guest orders are
// always DINE_IN (room service).
enum DiningMode {
  DINE_IN
  TAKEAWAY
}

enum OrderStatus {
  OPEN // running tab
  PARKED // held
  SETTLED // fully paid (walk-in)
  CHARGED_TO_ROOM // posted to folio
  VOID
}

enum KotStatus {
  NEW
  PREPARING
  READY
  SERVED
}

model Order {
  id             String      @id @default(cuid())
  orderNo        Int         @unique @default(autoincrement())
  clientKey      String?     @unique // offline-POS idempotency key
  type           OrderType
  diningMode     DiningMode  @default(DINE_IN)
  status         OrderStatus @default(OPEN)
  kotStatus      KotStatus   @default(NEW)
  roomId         String?
  room           Room?       @relation(fields: [roomId], references: [id])
  reservationId  String?
  reservation    Reservation? @relation(fields: [reservationId], references: [id])
  customerName   String? // walk-in label
  notes          String?
  subtotal       Int         @default(0)
  discount       Int         @default(0) // LKR cents (positive number, subtracted)
  discountReason String?
  discountById   String? // manager who authorized
  serviceCharge  Int         @default(0)
  vat            Int         @default(0)
  total          Int         @default(0)
  staffId        String
  staff          User        @relation(fields: [staffId], references: [id])
  createdAt      DateTime    @default(now())
  settledAt      DateTime?
  voidReason     String?

  items      OrderItem[]
  payments   Payment[]
  folioLines FolioLine[]

  @@index([status, createdAt])
}

model OrderItem {
  id         String   @id @default(cuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
  name       String // snapshot at order time
  qty        Int
  unitPrice  Int // snapshot, LKR cents
  amount     Int
  notes      String?
  voided     Boolean  @default(false)
  voidReason String?
}

enum PaymentMethod {
  CASH
  CARD // manual amount entry — TODO(Phase2): live terminal API
  LANKAQR
  BANK_TRANSFER
  CORPORATE_CREDIT // month-end billing
  LOYALTY_POINTS // redemption against bill
}

enum PaymentKind {
  PAYMENT
  DEPOSIT
  REFUND
}

model Payment {
  id                 String        @id @default(cuid())
  idempotencyKey     String?       @unique // offline-POS replay safety
  kind               PaymentKind   @default(PAYMENT)
  method             PaymentMethod
  amount             Int // LKR cents; refunds stored positive with kind=REFUND
  reference          String? // card slip no, bank ref, QR txn id
  reason             String? // MANDATORY for refunds (enforced in API)
  folioId            String?
  folio              Folio?        @relation(fields: [folioId], references: [id])
  orderId            String?
  order              Order?        @relation(fields: [orderId], references: [id])
  corporateAccountId String? // month-end settlement payments
  corporateAccount   CorporateAccount? @relation(fields: [corporateAccountId], references: [id])
  staffId            String
  staff              User          @relation(fields: [staffId], references: [id])
  shiftId            String?
  shift              Shift?        @relation(fields: [shiftId], references: [id])
  createdAt          DateTime      @default(now())

  @@index([createdAt])
}

// ─────────────────────────────────── Venues ──────────────────────────────────

model Venue {
  id          String         @id @default(cuid())
  name        String         @unique
  maxCapacity Int
  facilities  Json           @default("[]") // editable list (⚠ owner instruction §9)
  hourlyRate  Int // LKR cents — editable settings, not fixed
  halfDayRate Int
  fullDayRate Int
  active      Boolean        @default(true)
  propertyId  String
  property    Property       @relation(fields: [propertyId], references: [id])
  bookings    VenueBooking[]
  maintenanceIssues MaintenanceIssue[]
}

enum DurationType {
  HOURLY
  HALF_DAY
  FULL_DAY
}

enum VenueBookingStatus {
  INQUIRY
  CONFIRMED
  COMPLETED
  CANCELLED
}

model VenueBooking {
  id           String             @id @default(cuid())
  code         String             @unique // VNB-0001
  venueId      String
  venue        Venue              @relation(fields: [venueId], references: [id])
  // client: either a hotel guest profile or an outside customer
  guestId      String?
  guest        Guest?             @relation(fields: [guestId], references: [id])
  clientName   String
  clientPhone  String?
  clientEmail  String?
  eventType    String? // wedding / party / corporate...
  date         DateTime           @db.Date
  startTime    String? // "10:00"
  endTime      String? // "16:00"
  durationType DurationType
  hours        Float? // when HOURLY
  guestCount   Int                @default(0)
  seating      String? // seating arrangement notes
  avNeeds      String?
  decoration   String?
  cateringByHotel Boolean         @default(false) // rental separate from catering
  notes        String?
  status       VenueBookingStatus @default(INQUIRY)
  depositDue   Int                @default(0) // from venue deposit % setting
  createdAt    DateTime           @default(now())
  cancelledAt  DateTime?
  cancelReason String?

  folio Folio?
}

// ───────────────────────── Housekeeping & maintenance ────────────────────────

enum TaskStatus {
  PENDING
  IN_PROGRESS
  DONE
}

model HousekeepingTask {
  id            String     @id @default(cuid())
  roomId        String
  room          Room       @relation(fields: [roomId], references: [id])
  assignedToId  String?
  assignedTo    User?      @relation(fields: [assignedToId], references: [id])
  status        TaskStatus @default(PENDING)
  checklist     Json // [{ item: string, done: boolean }] from room-type template
  notes         String?
  reservationId String? // checkout that triggered it
  createdAt     DateTime   @default(now())
  completedAt   DateTime?
}

enum CheckKind {
  CHECK_IN
  CHECK_OUT
}

// Room item verification at check-in/out (§4.6) — supports damage charges
model RoomItemCheck {
  id            String      @id @default(cuid())
  reservationId String
  reservation   Reservation @relation(fields: [reservationId], references: [id])
  roomId        String
  room          Room        @relation(fields: [roomId], references: [id])
  kind          CheckKind
  items         Json // [{ item: string, ok: boolean, note?: string }]
  staffId       String
  staff         User        @relation(fields: [staffId], references: [id])
  createdAt     DateTime    @default(now())
}

enum MaintenanceStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

model MaintenanceIssue {
  id              String            @id @default(cuid())
  roomId          String?
  room            Room?             @relation(fields: [roomId], references: [id])
  venueId         String?
  venue           Venue?            @relation(fields: [venueId], references: [id])
  description     String
  status          MaintenanceStatus @default(OPEN)
  loggedById      String
  loggedBy        User              @relation("loggedBy", fields: [loggedById], references: [id])
  resolutionNotes String?
  createdAt       DateTime          @default(now())
  resolvedAt      DateTime?
}

// ──────────────────────── Notifications, audit, misc ─────────────────────────

enum NotificationChannel {
  EMAIL
  WHATSAPP
  SMS
}

enum NotificationStatus {
  QUEUED
  SENT
  FAILED
}

model Notification {
  id        String              @id @default(cuid())
  type      String // BOOKING_CONFIRMATION | PRE_ARRIVAL | FEEDBACK_REQUEST | VENUE_CONFIRMATION | VENUE_PAYMENT_REMINDER | VENUE_PRE_EVENT | LOW_STOCK
  channel   NotificationChannel
  to        String
  subject   String
  body      String
  status    NotificationStatus  @default(QUEUED)
  refType   String?
  refId     String?
  createdAt DateTime            @default(now())
  sentAt    DateTime?
  error     String?
}

model AuditLog {
  id        String   @id @default(cuid())
  staffId   String?
  staff     User?    @relation(fields: [staffId], references: [id])
  action    String // e.g. ORDER_VOID, REFUND, DISCOUNT, SETTING_CHANGE, CHECKIN...
  entity    String
  entityId  String?
  details   Json?
  ipAddress String? // client IP of the request that triggered this action
  userAgent String? // browser/device user agent string
  route     String? // e.g. "POST /api/orders/:id/void"
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// Security role: visitor / vehicle log (per §4.8 — permissions to confirm)
model VisitorLog {
  id         String    @id @default(cuid())
  name       String
  vehicleNo  String?
  purpose    String?
  timeIn     DateTime  @default(now())
  timeOut    DateTime?
  loggedById String
  loggedBy   User      @relation(fields: [loggedById], references: [id])
}

model NightAudit {
  id           String   @id @default(cuid())
  businessDate DateTime @unique @db.Date
  data         Json // full computed snapshot: revenue, occupancy, cash, variances
  runById      String
  runBy        User     @relation(fields: [runById], references: [id])
  runAt        DateTime @default(now())
}
