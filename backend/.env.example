APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

# Decoupled React SPA — used for CORS + Sanctum's stateful-domain check.
FRONTEND_URL=http://localhost:5173
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173,127.0.0.1,127.0.0.1:5173,::1

# ── PRODUCTION (SPA and API on different subdomains) ─────────────────────────
# When the SPA is on e.g. https://demo.hms.vellixglobal.com and the API is on
# https://api.demo.hms.vellixglobal.com, set (they share the parent domain, so
# the session/XSRF cookie can be scoped to it and read by the SPA):
#   APP_URL=https://api.demo.hms.vellixglobal.com
#   FRONTEND_URL=https://demo.hms.vellixglobal.com        # exact SPA origin (CORS)
#   SANCTUM_STATEFUL_DOMAINS=demo.hms.vellixglobal.com    # SPA host (no scheme)
#   SESSION_DOMAIN=.demo.hms.vellixglobal.com             # shared parent, leading dot
#   SESSION_SECURE_COOKIE=true                            # HTTPS
#   SESSION_SAME_SITE=lax                                 # same site (shared registrable domain)
# And in the SPA build: VITE_API_URL=https://api.demo.hms.vellixglobal.com

# Shared cPanel can't run a websocket server (Reverb) or a persistent queue
# worker, so realtime uses client-side polling (see web/src/lib/socket.ts) and
# `null` broadcasting means the server never tries to push. Keep these as-is.
BROADCAST_CONNECTION="null"
FILESYSTEM_DISK=local
# `sync` runs queued jobs (emails/notifications) inline — no worker/cron needed.
QUEUE_CONNECTION=sync

# Reverb is NOT used on shared cPanel. Only fill these (and set
# BROADCAST_CONNECTION=reverb|pusher|ably) if you later move to a host/service
# that supports real websockets.
# REVERB_APP_ID=
# REVERB_APP_KEY=
# REVERB_APP_SECRET=
# REVERB_HOST="localhost"
# REVERB_PORT=8080
# REVERB_SCHEME=http

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
